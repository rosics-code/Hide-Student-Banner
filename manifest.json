{
  "manifest_version": 3,
  "name": "Student Banner Disabler",
  "version": "1.0",
  "description": "This disabled the student de-activation message on Scratch.",
  "content_scripts": [
    {
      "matches": ["*://*.scratch.mit.edu/*", "*://*.scratch.org/*"],
      "css": ["imports.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["site-css/*.css"],
      "matches": ["*://*.scratch.mit.edu/*", "*://*.scratch.org/*"]
    }
  ]
}
